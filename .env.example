# Copy this file to .env (which is gitignored) and fill in real values
# for local development. In production, these are set in Netlify env vars.

# Required for the chatbot to use the real Claude API.
# If absent, the chat handler falls back to a stub echo response.
CLAUDE_API_KEY=

# Required for the booking flow (step 3). Bearer token from booq.now dashboard.
BOOQ_API_KEY=

# Required for the human-handoff Slack ping (step 4).
SLACK_WEBHOOK_URL=

# Required for visitor auto-confirmation emails (step 4).
RESEND_API_KEY=
